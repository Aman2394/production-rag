# ── LLM (Ollama — local, no API key required) ────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional: set LLM_PROVIDER=anthropic to use Claude instead
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Embeddings (local sentence-transformers — no API key required) ────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DEVICE=cpu          # cpu | cuda | mps

# Optional: set if switching back to OpenAI embeddings
# OPENAI_API_KEY=sk-...

# ── Reranker (local BGE cross-encoder — no API key required) ─────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu             # cpu | cuda | mps

# Optional: set if switching to Cohere Rerank API
# COHERE_API_KEY=...

# ── Vector Store ──────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=...              # Required for Qdrant Cloud; leave blank for local

# ── Observability ─────────────────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=...
LANGFUSE_PUBLIC_KEY=...
LANGFUSE_HOST=https://cloud.langfuse.com   # Override for self-hosted

LANGSMITH_API_KEY=...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=production-rag

# ── Memory — short-term (Redis) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HISTORY_TTL=86400         # seconds — 24h session expiry
REDIS_MAX_HISTORY=20            # max messages stored per session (10 turns)

# ── Memory — long-term (PostgreSQL, optional) ─────────────────────────────────
# Leave unset to disable long-term storage
# POSTGRES_URL=postgresql://user:password@localhost:5432/ragdb

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development                 # development | production

# ── Retrieval Tuning ──────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=20              # Candidates passed to reranker
RERANK_TOP_N=5                  # Final docs returned to LLM
QDRANT_COLLECTION_NAME=documents
